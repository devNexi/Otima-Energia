modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["alsa-lib", "at-spi2-atk", "cairo", "cups", "expat", "glib", "gtk3", "libdrm", "libxcrypt", "libxkbcommon", "mesa", "nss", "pango", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "xorg.libxcb"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 3456
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 3000

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[agent]
mockupState = "FULLSTACK"
integrations = ["javascript_database:1.0.0", "javascript_object_storage:1.0.0"]

[userenv]

[userenv.development]
ENABLE_DEMO_MODE = "true"

[userenv.shared]
ZOHO_INTAKE_KEY = "J7qK9xR2vN4mP8sT5wY3bL6cE1aH0fUz"
SMTP_HOST = "smtp.sendgrid.net"
SMTP_PORT = "587"
SMTP_USER = "apikey"
SMTP_FROM_EMAIL = "ops@otimaenergia.com"
SMTP_FROM_NAME = "Ótima Energia"
ENABLE_ZOHO_SNAPSHOT_SYNC = "true"
ENABLE_ZOHO_AUTO_CALLBACK_TASK = "true"
DEFAULT_CALLBACK_DELAY_MINUTES = "30"
BUSINESS_HOURS_START = "09:00"
BUSINESS_HOURS_END = "18:00"
NO_ACTIVITY_WARNING_DAYS = "10"
TIMEZONE = "America/Sao_Paulo"
WHATSAPP_AUTOMATION_ENABLED = "false"
PARSER_BASE_URL = "https://parser.otimaenergia.com"
